{
  "manifest_version": 3,
  "name": "Manhwa Translator",
  "version": "2.7.0",
  "description": "Переводчик манхвы с OCR",
  "permissions": ["activeTab", "tabs", "storage", "contextMenus"],
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://api.mymemory.translated.net/*",
    "https://tessdata.projectnaptha.com/*",
    "https://cdn.jsdelivr.net/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "commands": {
    "start-region": {
      "suggested_key": { "default": "Ctrl+Shift+R" },
      "description": "Выделить область для OCR"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/tesseract.min.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": { "service_worker": "background.js" }
}
